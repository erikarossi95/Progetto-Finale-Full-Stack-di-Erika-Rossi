# Snaply backend — copia in `.env` e personalizza.

# --- Database ---
DB_HOST=localhost
DB_NAME=snaply
DB_USER=root
DB_PASS=

# --- JWT ---
# Genera un secret robusto, es: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-with-a-long-random-string
JWT_EXPIRY=86400

# --- Upload ---
UPLOAD_DIR=uploads
# 26214400 = 25 MB
MAX_UPLOAD_SIZE=26214400

# --- CORS ---
# Lista separata da virgola degli origin ammessi.
ALLOWED_ORIGINS=http://localhost:5173
