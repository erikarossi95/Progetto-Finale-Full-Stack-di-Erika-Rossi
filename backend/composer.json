{
    "name": "snaply/backend",
    "description": "Snaply — API REST per la raccolta di foto/video degli eventi.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "Snaply\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Snaply\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    }
}
