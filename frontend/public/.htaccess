RewriteEngine On

# Backend PHP: API e media serviti dal front controller in api/public/
RewriteRule ^api(/.*)?$ api/public/index.php [L,QSA]
RewriteRule ^uploads/.*$ api/public/index.php [L,QSA]

# File/cartelle statiche esistenti: serviti direttamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback SPA: ogni altra rotta → index.html
RewriteRule ^ index.html [L]
