RewriteEngine On

# Passa l'header Authorization a PHP (su Apache/CGI altrimenti viene perso → JWT non arriva)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Backend PHP: API e media serviti dal front controller in api/public/
RewriteRule ^api(/.*)?$ api/public/index.php [L,QSA]
RewriteRule ^uploads/.*$ api/public/index.php [L,QSA]

# File/cartelle statiche esistenti: serviti direttamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback SPA: ogni altra rotta → index.html
RewriteRule ^ index.html [L]
